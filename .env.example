# ─── Zamanla environment configuration ───────────────────────────────────────
#
# Copy this file to .env and fill in values for your environment.
# The .env file is NEVER committed to git.
#
# Three environments:
#
#   LOCAL DEV   → docker compose up
#                 Frontend: http://localhost:9050
#                 Backend:  http://localhost:9051
#
#   SERVER DEV  → ./scripts/dev-start.sh
#                 Public URL: https://zamanla-dev.yildizsalih.com
#                 CORS_ORIGIN must match the dev domain
#
#   PRODUCTION  → ./scripts/deploy-prod.sh
#                 Public URL: https://zamanla.yildizsalih.com
#                 CORS_ORIGIN must match the production domain
#
# For server dev / production, set VITE_API_URL=/api (relative, nginx proxies).
# For local Docker dev,       set VITE_API_URL=http://localhost:9051/api.

# ─── Database ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=9052
DB_NAME=zamanla
DB_USER=zamanla
# Use a strong password in production. Must not contain # or spaces.
DB_PASSWORD=change_me_in_production

# ─── Server ──────────────────────────────────────────────────────────────────
# local dev:   development
# server dev:  development
# production:  production
NODE_ENV=development

PORT=9051

# ─── CORS ────────────────────────────────────────────────────────────────────
# Must match the exact origin the browser sends.
# local dev:   http://localhost:9050
# server dev:  https://zamanla-dev.yildizsalih.com
# production:  https://zamanla.yildizsalih.com
CORS_ORIGIN=http://localhost:9050

# ─── Security ────────────────────────────────────────────────────────────────
# Cloudflare Turnstile (optional — leave blank to disable)
# Server-side secret from https://dash.cloudflare.com → Turnstile
TURNSTILE_SECRET_KEY=

# Optional account auth (JWT in HttpOnly cookie)
# In production, set a strong random value and keep it secret.
# NOTE: tokens are stateless — changing the secret invalidates all sessions, but
# an individual token cannot be revoked before it expires (see DEPLOYMENT.md).
AUTH_JWT_SECRET=change_me_auth_jwt_secret
AUTH_JWT_EXPIRES_IN=7d
AUTH_COOKIE_NAME=zamanla_auth
AUTH_COOKIE_MAX_AGE_MS=604800000

# Express `trust proxy`. Hop count to the real client IP: "1" for a single nginx,
# "2" for Cloudflare + nginx. Also accepts true/false or a subnet/IP list.
TRUST_PROXY=1

# ─── Limits (guardrails) ─────────────────────────────────────────────────────
# Keep a single session from generating an unbounded number of slots.
MAX_SESSION_SPAN_DAYS=92
MAX_SESSION_SLOTS=5000
MAX_PARTICIPANTS_PER_SESSION=300

# ─── Anonymous session retention ─────────────────────────────────────────────
# Unclaimed (anonymous) sessions are auto-deleted this many days after their
# date range ends, so abandoned polls don't accumulate. Claiming a session
# (signing in and taking ownership) exempts it permanently.
ANON_SESSION_RETENTION_DAYS=30
# How often the in-process cleanup job runs (ms). Default 6 hours.
ANON_SESSION_CLEANUP_INTERVAL_MS=21600000
# Set to false to disable the in-process job (e.g. to run it from external cron).
ANON_SESSION_CLEANUP_ENABLED=true

# ─── Frontend (Vite build-time variables) ────────────────────────────────────
# These are baked into the frontend bundle at build time.
#
# local Docker dev:    http://localhost:9051/api
# server dev / prod:   /api  (relative — nginx routes /api/ to backend)
VITE_API_URL=http://localhost:9051/api

# Cloudflare Turnstile site key (public — safe to include in frontend bundle)
# Must match the domain registered in your Turnstile dashboard
VITE_TURNSTILE_SITE_KEY=

# ─── HMR (server dev only, docker-compose.dev.yml) ───────────────────────────
# These configure Vite's hot-reload WebSocket for the remote dev environment.
# Only needed when running ./scripts/dev-start.sh on the server.
# Leave blank for local development.
HMR_HOST=zamanla-dev.yildizsalih.com
HMR_CLIENT_PORT=443
HMR_PROTOCOL=wss
