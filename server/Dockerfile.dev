FROM node:20-alpine

WORKDIR /app

# Install all deps including devDependencies (nodemon lives here)
COPY package*.json ./
RUN npm ci

# Source is bind-mounted at runtime — COPY is not needed for hot reload,
# but we keep it so the image is self-contained if volumes are not mounted.
COPY . .

EXPOSE 9051

CMD ["npm", "run", "dev"]
